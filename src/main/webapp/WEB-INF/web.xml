<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.xml: 웹 애플리케이션 설정 파일 (배포 서술자, Deployment Descriptor)
  Tomcat이 서버를 시작할 때 이 파일을 읽어서 앱 설정을 적용함
  version="6.0": Servlet 6.0 스펙 사용 (Jakarta EE 10 / Tomcat 10.1)
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

  <display-name>N3 일본어 학습 백엔드</display-name>

  <!--
    서블릿 URL 매핑은 각 서블릿 클래스에
    @WebServlet("/api/signup") 어노테이션으로 등록했기 때문에
    여기서는 별도로 등록하지 않아도 됨

    이 파일에서는 앱 전체 설정(인코딩 필터 등)만 관리
  -->

  <!--
    EncodingFilter: 모든 요청·응답에 UTF-8 인코딩을 강제 적용하는 필터
    한글·일본어 문자가 깨지지 않도록 방지
  -->
  <filter>
    <filter-name>EncodingFilter</filter-name>
    <filter-class>com.nihongo.filter.EncodingFilter</filter-class>
  </filter>
  <!--
    /*: 모든 URL 경로에 이 필터 적용
  -->
  <filter-mapping>
    <filter-name>EncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

</web-app>
